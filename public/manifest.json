{
  "manifest_version": 3,
  "name": "DevLens",
  "version": "1.0.0",
  "description": "All-in-one browser extension for web developers",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "commands": {
    "toggle-panel": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Toggle DevLens panel"
    },
    "toggle-inspector": {
      "suggested_key": {
        "default": "Alt+Shift+I"
      },
      "description": "Toggle Inspector tool"
    },
    "toggle-eyedropper": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "Toggle Color Eyedropper"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["panel.html", "*.js", "*.css", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
